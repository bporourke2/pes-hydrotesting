# Copy to .env and fill in values. Never commit .env to git.

# Flask
SECRET_KEY=change-me-to-a-random-secret
# Restrict WebSocket CORS to your deployment origin (e.g. https://hydro.example.com)
# Defaults to '*' (open) if not set — always set this in production
ALLOWED_ORIGIN=https://hydro.example.com
# Set to '1' to enable Werkzeug debug mode — NEVER enable in production
FLASK_DEBUG=0

# Authentik OIDC
# In Authentik: Applications > Providers > Create OAuth2/OIDC Provider
#   - Redirect URI: https://hydro.thebrendan.online/auth/callback
#   - Client type: Confidential
# Then create an Application linked to that provider and note the slug.
AUTHENTIK_CLIENT_ID=your-client-id-here
AUTHENTIK_CLIENT_SECRET=your-client-secret-here
# The slug of your Authentik application (from Applications > your app > Slug)
AUTHENTIK_APP_SLUG=hydrotest
# Base URL of your Authentik instance (e.g. https://auth.example.com)
AUTHENTIK_ISSUER_URL=https://auth.example.com
